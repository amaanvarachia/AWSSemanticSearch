{
    "Version": "2012-10-17",
    "Statement": [
      {
        "Sid": "S3InputBucketAccess",
        "Effect": "Allow",
        "Action": [
          "s3:GetObject",
          "s3:ListBucket"
        ],
        "Resource": [
          "arn:aws:s3:::customer-embedding-input-bucket",
          "arn:aws:s3:::customer-embedding-input-bucket/*"
        ]
      },
      {
        "Sid": "S3OutputBucketAccess",
        "Effect": "Allow",
        "Action": [
          "s3:PutObject"
        ],
        "Resource": [
          "arn:aws:s3:::customer-embedding-output-bucket/*"
        ]
      },
      {
        "Sid": "BedrockInvokeModel",
        "Effect": "Allow",
        "Action": [
          "bedrock:InvokeModel"
        ],
        "Resource": "*"
      },
      {
        "Sid": "CloudWatchLogs",
        "Effect": "Allow",
        "Action": [
          "logs:CreateLogGroup",
          "logs:CreateLogStream",
          "logs:PutLogEvents"
        ],
        "Resource": "*"
      }
    ]
  }
  